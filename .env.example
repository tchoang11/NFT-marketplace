# Pinata IPFS JWT tokens — get them from https://app.pinata.cloud (API Keys)
# Prefixed with NEXT_PUBLIC_ so Next.js exposes them to the browser.
NEXT_PUBLIC_PINATA_JWT_IMAGE=your_pinata_jwt_here
NEXT_PUBLIC_PINATA_JWT_META=your_pinata_jwt_here

# Sepolia testnet RPC URL (e.g. from Alchemy or Infura).
# Used both by Hardhat to deploy and by the frontend to read on-chain data.
# Leave empty to use the local Hardhat node (http://127.0.0.1:8545).
NEXT_PUBLIC_RPC_URL=

# Private key of the wallet used to DEPLOY the contract (Hardhat only).
# Use a throwaway/test wallet — never one holding real funds.
# NOT prefixed with NEXT_PUBLIC_ so it stays server-side and is never sent to Vercel.
PRIVATE_KEY=
